# Shared environment for the OpenIDX backend services (systemd EnvironmentFile).
# Copy to a persistent path (e.g. ~/.config/oidx/common.env) and fill in real
# values. NEVER commit real secrets — these are placeholders.
DATABASE_URL=postgres://openidx:CHANGE_ME@localhost:55432/openidx?sslmode=disable
REDIS_URL=redis://localhost:56379
APP_ENV=development
JWT_SECRET=CHANGE_ME_min_32_chars
ENCRYPTION_KEY=CHANGE_ME_exactly_32_bytes_______
OAUTH_ISSUER=https://openidx.tdv.org
OAUTH_JWKS_URL=http://localhost:8006/.well-known/jwks.json
DEFAULT_ORG_FALLBACK=true
CORS_ALLOWED_ORIGINS=https://openidx.tdv.org
WEBAUTHN_RP_ID=openidx.tdv.org
WEBAUTHN_RP_ORIGINS=https://openidx.tdv.org
LOG_LEVEL=info
