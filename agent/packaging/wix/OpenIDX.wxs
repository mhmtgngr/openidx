<?xml version="1.0" encoding="UTF-8"?>
<!--
  OpenIDX Windows client MSI (WiX v4/v5).

  Build:
    wix build agent/packaging/wix/OpenIDX.wxs \
      -d Version=1.0.0 -d ExePath=dist/openidx-agent.exe \
      -arch x64 -o dist/OpenIDX.msi

  Installs the single openidx-agent.exe, registers + starts the Windows service
  (posture loop), and launches the tray at user login. Silent/GPO/Intune:
    msiexec /i OpenIDX.msi /qn SERVER_URL=https://openidx.example.com ENROLL_TOKEN=...
  ENROLL_TOKEN triggers a one-shot device enrollment during install (best-effort).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package Name="OpenIDX Agent"
           Manufacturer="OpenIDX"
           Version="$(var.Version)"
           UpgradeCode="6f4a1e2c-2b7d-4b1a-9c3e-0a1b2c3d4e5f"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of OpenIDX Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Branding: the multi-resolution shield icon, shown in Add/Remove
         Programs and on the Start-Menu shortcut. Path is relative to this .wxs. -->
    <Icon Id="OpenIDXIcon" SourceFile="$(sys.SOURCEFILEDIR)..\..\assets\openidx.ico" />
    <Property Id="ARPPRODUCTICON" Value="OpenIDXIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/mhmtgngr/openidx" />

    <!-- Public properties usable from a silent msiexec command line. -->
    <Property Id="SERVER_URL" Secure="yes" />
    <Property Id="ENROLL_TOKEN" Secure="yes" Hidden="yes" />
    <!-- Optional: the update manifest URL persisted at enroll so the service
         self-updates. e.g. https://github.com/<owner>/<repo>/releases/latest/download/latest.json -->
    <Property Id="UPDATE_MANIFEST_URL" Secure="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OpenIDX" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="OpenIDX" />
    </StandardDirectory>

    <ComponentGroup Id="AppComponents" Directory="INSTALLFOLDER">
      <!-- The agent binary + the Windows service definition. -->
      <Component Id="AgentExe">
        <File Id="AgentExeFile" Name="openidx-agent.exe" Source="$(var.ExePath)" KeyPath="yes" />
        <ServiceInstall Id="OpenIDXAgentSvc"
                        Name="OpenIDXAgent"
                        DisplayName="OpenIDX Agent"
                        Description="OpenIDX device-trust agent (enrollment, posture, OpenZiti connectivity)."
                        Type="ownProcess"
                        Start="auto"
                        ErrorControl="normal"
                        Account="LocalSystem"
                        Arguments="service run --config-dir &quot;[CommonAppDataFolder]OpenIDX\agent&quot;" />
        <ServiceControl Id="OpenIDXAgentSvcCtl"
                        Name="OpenIDXAgent"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>

      <!-- Optional: the libvpx runtime DLL that the screen-share (VP8) build
           links against. Included only when the build passes -d VpxDll=<path>
           (the CI screenshare build does; the pure-Go build omits it). -->
      <?ifdef VpxDll ?>
      <Component Id="VpxRuntime">
        <File Id="VpxDllFile" Source="$(var.VpxDll)" KeyPath="yes" />
      </Component>
      <?endif?>

      <!-- Optional: the MinGW pthread runtime DLL. The CGO/MinGW screen-share
           build normally static-links this (see windows-client-build.yml), but
           when it is shipped as a fallback the build passes -d PthreadDll=<path>
           so a clean box without a MinGW toolchain can still launch the exe
           (missing libwinpthread-1.dll -> 0xC0000135 -> service 1920 -> 1603). -->
      <?ifdef PthreadDll ?>
      <Component Id="PthreadRuntime">
        <File Id="PthreadDllFile" Source="$(var.PthreadDll)" KeyPath="yes" />
      </Component>
      <?endif?>

      <!-- Launch the tray for the interactive user at login. -->
      <Component Id="TrayAutostart">
        <RegistryValue Root="HKMU"
                       Key="Software\Microsoft\Windows\CurrentVersion\Run"
                       Name="OpenIDXTray"
                       Type="string"
                       Value="&quot;[INSTALLFOLDER]openidx-agent.exe&quot; tray"
                       KeyPath="yes" />
      </Component>

      <!-- Start-Menu shortcut to (re)launch the tray, carrying the app icon. -->
      <Component Id="StartMenuShortcut" Directory="AppShortcutFolder">
        <Shortcut Id="TrayShortcut"
                  Name="OpenIDX"
                  Description="Open the OpenIDX tray (sign in, connections, status)"
                  Target="[INSTALLFOLDER]openidx-agent.exe"
                  Arguments="tray"
                  Icon="OpenIDXIcon"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveAppShortcutFolder" On="uninstall" />
        <RegistryValue Root="HKMU"
                       Key="Software\OpenIDX\Agent"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="Main" Title="OpenIDX Agent" Level="1">
      <ComponentGroupRef Id="AppComponents" />
    </Feature>

    <!--
      Silent enroll-at-install: when SERVER_URL + ENROLL_TOKEN are supplied,
      run `openidx-agent enroll` after files are laid down. Use a REUSABLE
      bootstrap token (see the reusable flag on /agent/tokens) so one token
      serves the whole fleet:
        msiexec /i OpenIDX.msi /qn SERVER_URL=https://openidx.example.com ENROLL_TOKEN=<REUSABLE>
      Deferred + no-impersonate (runs as LocalSystem, same account as the
      service). Return=ignore so a transient enroll failure never blocks the
      install (the service/tray can enroll later).
    -->
    <SetProperty Id="EnrollDevice"
                 Sequence="execute"
                 Before="EnrollDevice"
                 Value="&quot;[INSTALLFOLDER]openidx-agent.exe&quot; enroll --server &quot;[SERVER_URL]&quot; --token &quot;[ENROLL_TOKEN]&quot; --manifest-url &quot;[UPDATE_MANIFEST_URL]&quot; --config-dir &quot;[CommonAppDataFolder]OpenIDX\agent&quot;"
                 Condition="SERVER_URL AND ENROLL_TOKEN" />
    <CustomAction Id="EnrollDevice"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />
    <InstallExecuteSequence>
      <Custom Action="EnrollDevice" After="InstallServices"
              Condition="SERVER_URL AND ENROLL_TOKEN AND NOT Installed" />
    </InstallExecuteSequence>
  </Package>
</Wix>
